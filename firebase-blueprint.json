{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "name", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "E-commerce product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "stock": { "type": "number" }
      },
      "required": ["name", "price", "image", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Processing", "Shipped", "Delivered", "Cancelled", "Returned"] },
        "paymentMethod": { "type": "string", "enum": ["COD", "Online"] },
        "paymentScreenshot": { "type": "string" },
        "shippingDetails": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "paymentMethod", "shippingDetails"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["name", "image"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Store settings",
      "type": "object",
      "properties": {
        "adminQR": { "type": "string" },
        "upiId": { "type": "string" }
      }
    },
    "Ticket": {
      "title": "Ticket",
      "description": "Support ticket",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["Open", "Closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "subject", "message"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store products"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories"
    },
    "/settings/general": {
      "schema": "Settings",
      "description": "Global store settings"
    },
    "/tickets/{ticketId}": {
      "schema": "Ticket",
      "description": "Support tickets"
    },
    "/admins/{adminId}": {
      "schema": { "type": "object", "properties": { "uid": { "type": "string" } } },
      "description": "List of admin UIDs"
    }
  }
}
