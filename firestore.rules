rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == 'nekoslayer20@gmail.com' || request.auth.token.email == 'admin@gmail.com')
      ); 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'role']) &&
             data.email is string && data.email.size() <= 200 &&
             data.name is string && data.name.size() <= 200 &&
             data.role in ['user', 'admin'] &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 20)) &&
             (!('address' in data) || (data.address is string && data.address.size() <= 1000));
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'image', 'category']) &&
             data.name is string && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.image is string && data.image.size() <= 1000 &&
             data.category is string && data.category.size() <= 100;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'status', 'paymentMethod', 'shippingDetails']) &&
             data.userId == request.auth.uid &&
             data.items is list && data.items.size() <= 50 &&
             data.total is number && data.total >= 0 &&
             data.status in ['Processing', 'Shipped', 'Delivered', 'Cancelled', 'Returned'] &&
             data.paymentMethod in ['COD', 'Online'];
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); 
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'user';
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'address', 'updatedAt'])) ||
        isAdmin()
      );
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(incoming());
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming()) && incoming().status == 'Processing';
      allow update: if isSignedIn() && (
        (isOwner(existing().userId) && incoming().userId == existing().userId && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'shippingDetails']) &&
         incoming().status == 'Cancelled' && existing().status == 'Processing') ||
        (isAdmin() && isValidOrder(incoming()))
      );
    }

    match /settings/general {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /tickets/{ticketId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed via console or a specific internal tool
    }
  }
}
